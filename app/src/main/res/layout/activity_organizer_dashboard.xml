<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.OrganizerDashboardActivity">

    <TextView
        android:id="@+id/tvOrganizerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Organizer Dashboard"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnCreateEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ Create"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="@id/tvOrganizerTitle"
        app:layout_constraintEnd_toStartOf="@id/btnOrgLogout"
        app:layout_constraintTop_toTopOf="@id/tvOrganizerTitle" />

    <Button
        android:id="@+id/btnOrgLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:backgroundTint="#6B7280"
        app:layout_constraintBottom_toBottomOf="@id/tvOrganizerTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvOrganizerTitle" />

    <TextView
        android:id="@+id/tvEmptyOrganizer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:gravity="center"
        android:text="No events yet.\nTap '+ Create Event' to get started."
        android:textColor="#6B7280"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOrganizerTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrganizerEvents"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOrganizerTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>

